{
  "name": "@sinphife/attend",
  "version": "1.1.3",
  "description": "Local web dashboard for AI coding sessions, with integrations for Claude Code, Codex/ChatGPT, and Cursor CLI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvinfunborn/attend.git"
  },
  "homepage": "https://github.com/alvinfunborn/attend#readme",
  "bugs": {
    "url": "https://github.com/alvinfunborn/attend/issues"
  },
  "keywords": [
    "claude-code",
    "codex",
    "ai-agents",
    "dashboard",
    "cli",
    "attention",
    "brief"
  ],
  "type": "module",
  "bin": {
    "attend": "dist/cli.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "dev:watch": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "shot": "node scripts/shot.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test",
    "format": "biome format --write src test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.12.29",
    "mermaid": "^11.16.0",
    "open": "^10.1.0",
    "pako": "^3.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "esbuild": "^0.28.1",
    "playwright": "^1.60.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "license": "MIT"
}
