{
  "name": "attend",
  "version": "1.0.0",
  "description": "Local web dashboard for brief-based AI session management across Claude Code + Codex. session = cache, brief = state.",
  "keywords": [
    "claude-code",
    "codex",
    "ai-agents",
    "dashboard",
    "cli",
    "attention",
    "brief"
  ],
  "type": "module",
  "bin": {
    "attend": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "dev:watch": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "shot": "node scripts/shot.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test",
    "format": "biome format --write src test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.158",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "playwright": "^1.60.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}
